# Required — Groq Whisper for push-to-talk transcription
GROQ_API_KEY=

# Required — ElevenLabs TTS for Kat's voice
ELEVENLABS_API_KEY=

# Optional — defaults shown below
# KAT_VOICE_SOURCE=pitch  # pitch => jqcCZkN6Knx8BJ5TBdYR, app => pFZP5JQG7iQjIQuC4Bku
# ELEVENLABS_VOICE_ID=jqcCZkN6Knx8BJ5TBdYR
# ELEVENLABS_MODEL_ID=eleven_turbo_v2

# Optional — Dune deck visual regeneration
# REPLICATE_API_KEY=

# Optional — public origin for generated share/canonical URLs.
# Production Vercel builds default to https://katechon.technology.
# KATECHON_PUBLIC_URL=https://katechon.technology

# Optional — dashboard narration. Defaults off for deterministic local/investor demos.
# DASHBOARD_NARRATION_REMOTE=0
# DASHBOARD_NARRATION_TTS=0

# Optional — live-linked sibling pitch deck dashboard.
# Start it with: npm run pitch:dev
# PITCH_DECK_URL=http://127.0.0.1:5174/deck/
# PITCH_DECK_DIST_DIR=../katechon-pitch/dist

# Optional — experimental. Keep off unless HLS audio muxing is being tested.
# ENABLE_HLS_AUDIO=0
# STREAM_AUDIO_ENABLED=0

# Optional — override the remote HLS control URL (default: http://localhost:9095)
# HLS_CONTROL_URL=http://localhost:9095

# Optional — opt into the remote SPECTRE dashboard tunnel.
# Defaults off so /dashboards/spectre/ uses the local HTML fallback.
# ENABLE_SPECTRE_TUNNEL=0

# Optional — pre-seed known session IDs (auto-discovered if not set)
# MINECRAFT_SESSION_ID=minecraft-xxxxxxxx
# NEWS_SESSION_ID=playwright-browser-xxxxxxxx

# Optional — port for the local Express server (default: 4040)
# PORT=4040
